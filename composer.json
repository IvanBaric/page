{
    "name": "ivanbaric/pages",
    "description": "Reusable CMS page-builder foundation for Laravel.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "ivanbaric/admin-ui": "dev-main",
        "ivanbaric/corexis": "dev-main as 1.0.0",
        "ivanbaric/gallery": "dev-main",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../corexis",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../admin-ui",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../gallery",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "IvanBaric\\Pages\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IvanBaric\\Pages\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "IvanBaric\\Pages\\PagesServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
